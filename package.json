{
  "name": "globalise-webapp",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "npm -w @globalise/app run dev",
    "build": "npm t && npm run typecheck && npm run lint && npm -w @globalise/app run build",
    "preview": "npm -w @globalise/app run preview",
    "typecheck": "tsc -b --clean && tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@types/lodash": "^4.17.24",
    "lodash": "^4.18.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tanstack/eslint-plugin-router": "^1.162.0",
    "@types/openseadragon": "^5.0.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.6.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
